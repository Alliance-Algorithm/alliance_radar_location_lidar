#!/bin/bash
set -uo pipefail

: "${RADAR_WS:=/workspace}"

SRC_BASE="${RADAR_WS}/ros_ws/src"

echo "Formatting radar packages..."
for pkg in radar_lidar radar_camera radar_fusion radar_bridge radar_calibration radar_bringup; do
    PKG_DIR="${SRC_BASE}/${pkg}"
    if [ -d "${PKG_DIR}" ]; then
        count=$(find "${PKG_DIR}" -type f \( -name '*.cpp' -o -name '*.hpp' \) | wc -l)
        if [ "$count" -gt 0 ]; then
            echo "  ${pkg} (${count} files)..."
            find "${PKG_DIR}" -type f \( -name '*.cpp' -o -name '*.hpp' \) -exec clang-format -i {} +
        else
            echo "  ${pkg} - no source files"
        fi
    else
        echo "  ${pkg} - directory not found"
    fi
done
echo "[OK] Formatted all .cpp and .hpp files."
