#!/bin/bash
# build-all - Build all packages (colcon + offline tools)
# Usage: build-all [Release|Debug] [extra colcon args...]
#
# Incremental build: only recompiles changed files.
# For a clean rebuild, run clean-radar first.
set -euo pipefail

: "${RADAR_WS:=/workspace}"
BUILD_TYPE="Release"

EXTRA_ARGS=()
for arg in "$@"; do
    case "$arg" in
        Release|Debug)
            BUILD_TYPE="$arg"
            ;;
        --clean)
            echo "> ERROR: --clean is removed. Use 'clean-radar' script instead." >&2
            exit 2
            ;;
        *)
            EXTRA_ARGS+=("$arg")
            ;;
    esac
done
set -- "${EXTRA_ARGS[@]}"

if [[ ! -d "${RADAR_WS}/ros_ws" ]]; then
    echo "> ERROR: Workspace not found: ${RADAR_WS}/ros_ws"
    exit 1
fi

cd "${RADAR_WS}"/ros_ws || exit 1

# ── ROS env ──────────────────────────────────────────────────────
export COLCON_LOG_PATH="${RADAR_WS}/ros_ws/log"
mkdir -p "${COLCON_LOG_PATH}"

if [ -f /opt/ros/jazzy/setup.bash ]; then
    set +u; source /opt/ros/jazzy/setup.bash; set -u
else
    echo "> ERROR: ROS2 Jazzy not found" >&2
    exit 1
fi

# ── validate source dirs exist ────────────────────────────────────
for src_dir in \
    "${RADAR_WS}/ros_ws/src" \
    "${RADAR_WS}/ros_ws/third-party" \
    "${RADAR_WS}/lidar_ros_driver/odin_ros_driver"; do
    if [[ ! -d "$src_dir" ]]; then
        echo "> WARNING: Source dir not found: $src_dir"
    fi
done

# ── colcon build (incremental) ───────────────────────────────────
echo "> Building all packages (${BUILD_TYPE}) ..."

CLICOLOR_FORCE=1 colcon build \
    --base-paths \
        src \
        third-party \
        "${RADAR_WS}/lidar_ros_driver/odin_ros_driver" \
    --symlink-install \
    --cmake-args \
        -DCMAKE_BUILD_TYPE="${BUILD_TYPE}" \
        -DCMAKE_EXPORT_COMPILE_COMMANDS=1 \
        -DCMAKE_CXX_FLAGS="-Wno-missing-field-initializers -Wno-unused-parameter" \
        -Wno-dev \
    "$@"

# ── merge compile_commands.json for clangd ──
python3 - <<'PY'
import json
import os
from pathlib import Path

workspace = Path(os.environ.get("RADAR_WS", "/workspace")).resolve()
build_root = Path("build")
merged = []
for path in sorted(build_root.glob("*/compile_commands.json")):
    merged.extend(json.loads(path.read_text()))

if not merged:
    print("> clangd: no compile_commands.json entries found")
else:
    payload = json.dumps(merged, indent=2) + "\n"
    # Write root + ros_ws + ros_ws/build for clangd discovery.
    outs = (
        workspace / "compile_commands.json",
        workspace / "ros_ws" / "compile_commands.json",
        workspace / "ros_ws" / "build" / "compile_commands.json",
    )
    for out in outs:
        out.parent.mkdir(parents=True, exist_ok=True)
        out.write_text(payload)
        print(f"> clangd: {len(merged)} container entries -> {out}")
PY

# ── build offline tools (pure CMake, not ament packages) ────────
for tool_dir in \
    "${RADAR_WS}/tools/model_to_map"; do
    if [[ ! -d "$tool_dir" ]]; then
        echo "> WARNING: Tool dir not found: $tool_dir"
        continue
    fi
    echo "> Building tool: $(basename "$tool_dir")"
    cmake -S "$tool_dir" -B "$tool_dir/build" \
        -DCMAKE_BUILD_TYPE="${BUILD_TYPE}" \
        -DCMAKE_EXPORT_COMPILE_COMMANDS=1 \
        -Wno-dev 2>&1 | tail -3
    cmake --build "$tool_dir/build" -j"$(nproc)" 2>&1 | tail -5
done

echo ">>"
