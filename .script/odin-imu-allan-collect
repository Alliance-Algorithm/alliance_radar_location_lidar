#!/bin/bash
# odin-imu-allan-collect - 采集 Odin1 IMU 静止数据用于 Allan 方差分析
#
# 用法:
#   odin-imu-allan-collect [duration_minutes]   # 默认 10 分钟
#
# 要求: 设备必须完全静止（放桌面/地面，不要触碰），采集期间禁止震动。
# Allan 方差需要足够长的数据才能看到 bias instability 拐点，
# 10分钟是快速验证用的下限，正式标定建议 60分钟+。
set -uo pipefail

: "${RADAR_WS:=/workspace}"
DURATION_MIN="${1:-10}"
DURATION_SEC=$((DURATION_MIN * 60))

BAG_DIR="/tmp/odin_imu_allan_$(date +%Y%m%d_%H%M%S)"

echo "═══════════════════════════════════════════════════"
echo "  Odin1 IMU Allan 方差数据采集"
echo "  时长: ${DURATION_MIN} 分钟"
echo "  输出: ${BAG_DIR}"
echo "═══════════════════════════════════════════════════"
echo ""
echo "  ► 请将设备放置在稳固平面上，采集期间禁止触碰/震动"
echo ""

set +u
source /opt/ros/jazzy/setup.bash
source "${RADAR_WS}/ros_ws/install/setup.bash"
set -u

pkill -9 -f host_sdk_sample 2>/dev/null || true
pkill -9 -f radar_fast_livo2_node 2>/dev/null || true
pkill -9 -f "ros2 launch" 2>/dev/null || true
sleep 2

echo "[1/3] 启动 Odin1 驱动（仅 IMU，不需要 LIO 节点）..."
LD_PRELOAD=$(gcc -print-file-name=libasan.so) \
    ros2 launch radar_bringup odin_fast_livo2_mapping.launch.py \
    > "${BAG_DIR}.driver.log" 2>&1 &
DRIVER_PID=$!
mkdir -p "$(dirname "$BAG_DIR")"
sleep 8

echo "[2/3] 验证 IMU 数据流 ..."
IMU_HZ=$(timeout 3 ros2 topic hz /odin1/imu 2>/dev/null | grep "average rate" | tail -1)
if [ -z "$IMU_HZ" ]; then
    echo "  ✗ /odin1/imu 无数据，检查设备连接"
    kill "$DRIVER_PID" 2>/dev/null
    exit 1
fi
echo "  ✓ /odin1/imu: $IMU_HZ"
echo ""

echo "[3/3] 录制 ${DURATION_MIN} 分钟 IMU 数据 ..."
# Cleanup on any exit
cleanup_allan() {
    [[ -n "${DRIVER_PID:-}" ]] && kill "$DRIVER_PID" 2>/dev/null || true
    [[ -n "${BAG_PID:-}" ]] && kill "$BAG_PID" 2>/dev/null || true
    pkill -9 -f host_sdk_sample 2>/dev/null || true
    pkill -9 -f "ros2 bag" 2>/dev/null || true
}
trap cleanup_allan EXIT INT TERM

ros2 bag record -o "$BAG_DIR" /odin1/imu &
BAG_PID=$!

for ((t=1; t<=DURATION_SEC; t++)); do
    filled=$(( t * 30 / DURATION_SEC ))
    (( filled > 30 )) && filled=30
    empty=$(( 30 - filled ))
    filled_str="" empty_str=""
    (( filled > 0 )) && filled_str=$(printf '█%.0s' $(seq 1 "$filled"))
    (( empty > 0 ))  && empty_str=$(printf '░%.0s' $(seq 1 "$empty"))
    pct=$(( t * 100 / DURATION_SEC ))
    printf "\r  [%s%s] %3d%%  %ds/%ds\033[K" "$filled_str" "$empty_str" "$pct" "$t" "$DURATION_SEC"
    sleep 1
done
printf "\n"

kill "$BAG_PID" 2>/dev/null
sleep 2  # 等 bag 文件 flush

echo ""
echo "═══════════════════════════════════════════════════"
echo "  采集完成: ${BAG_DIR}"
echo "  下一步: odin-imu-allan-analyze ${BAG_DIR}"
echo "═══════════════════════════════════════════════════"
