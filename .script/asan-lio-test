#!/bin/bash
# asan-lio-test - Record bag + replay LIO under ASAN
set -eo pipefail

: "${RADAR_WS:=/workspace}"
BAG_DIR="/tmp/asan_bag_$(date +%Y%m%d_%H%M%S)"
ASAN_LOG="/tmp/asan_lio"
DRIVER_PID="" BAG_PID="" LIO_PID=""

# Cleanup on any exit
cleanup_asan() {
    [[ -n "${DRIVER_PID:-}" ]] && kill "$DRIVER_PID" 2>/dev/null || true
    [[ -n "${BAG_PID:-}" ]] && kill "$BAG_PID" 2>/dev/null || true
    [[ -n "${LIO_PID:-}" ]] && kill "$LIO_PID" 2>/dev/null || true
    pkill -9 -f host_sdk_sample 2>/dev/null || true
    pkill -9 -f radar_fast_livo2 2>/dev/null || true
    pkill -9 -f ros2.bag 2>/dev/null || true
}
trap cleanup_asan EXIT INT TERM

set +u
source /opt/ros/jazzy/setup.bash
source "${RADAR_WS}/ros_ws/install/setup.bash"
set -u

# ── 1. Cleanup ──
pkill -9 -f host_sdk_sample 2>/dev/null || true
pkill -9 -f radar_fast_livo2 2>/dev/null || true
sleep 1
rm -f ${ASAN_LOG}.* 2>/dev/null || true

# ── 2. Record bag (10s) ──
echo "[1/4] Starting driver + recording 10s..."
timeout 15 ros2 run odin_ros_driver host_sdk_sample --ros-args \
  -p config_file:=${RADAR_WS}/ros_ws/src/radar_bringup/config/lidar/odin_driver_lio.yaml &
DRIVER_PID=$!
sleep 4

timeout 12 ros2 bag record -o "$BAG_DIR" /odin1/imu /odin1/cloud_raw 2>/dev/null &
BAG_PID=$!
sleep 12
kill $BAG_PID $DRIVER_PID 2>/dev/null || true
pkill -9 -f host_sdk_sample 2>/dev/null || true

echo "[1/4] Done. $(du -sh $BAG_DIR 2>/dev/null | cut -f1)"

# ── 3. Replay + ASAN ──
echo "[2/4] Starting LIO node with ASAN..."
pkill -9 -f radar_fast_livo2 2>/dev/null || true
sleep 1

ASAN_OPTIONS=halt_on_error=0:log_path=$ASAN_LOG \
  ros2 run radar_fast_livo2 radar_fast_livo2_node --ros-args \
    --params-file ${RADAR_WS}/ros_ws/src/radar_fast_livo2/config/odin_livo2.yaml \
    > /tmp/lio_stdout.log 2>&1 &
LIO_PID=$!
sleep 3

echo "[3/4] Playing bag..."
BAG_FILE=$(ls $BAG_DIR/*.mcap 2>/dev/null | head -1)
if [ -z "$BAG_FILE" ]; then
  echo "ERROR: No mcap file in $BAG_DIR"
  exit 1
fi

timeout 15 ros2 bag play "$BAG_FILE" --clock 100 2>/dev/null &
sleep 15

# ── 4. Results ──
echo "[4/4] Results:"
echo ""
echo "=== LIO stdout ==="
cat /tmp/lio_stdout.log
echo ""

if ls ${ASAN_LOG}.* 2>/dev/null | head -1 > /dev/null; then
  echo "=== ASAN Report ==="
  cat ${ASAN_LOG}.* | head -80
else
  echo "No ASAN report (no crash detected)"
fi

pkill -9 -f radar_fast_livo2 2>/dev/null || true
pkill -9 -f ros2.bag 2>/dev/null || true
