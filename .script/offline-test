#!/bin/bash
# offline-test - launch offline registration visualization node
#
# Usage:
#   offline-test <scan.pcd> --map <map.pcd> [extra ros2 launch args...]
#
# Result:
#   publishes /offline/map /offline/scan_raw /offline/scan_aligned /offline/overlay
#   and /offline/pose for Foxglove inspection

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
: "${RADAR_WS:=$(cd "${SCRIPT_DIR}/.." && pwd -P)}"
DEFAULT_MAP_PCD="${RADAR_WS}/model/generated/map.pcd"

SCAN_PCD=""
MAP_PCD=""
EXTRA_ARGS=()

resolve_path() {
    local input="$1"
    if [[ "$input" = /* ]]; then
        printf '%s\n' "$input"
    else
        printf '%s\n' "$(cd "$PWD" && pwd -P)/$input"
    fi
}

while [[ $# -gt 0 ]]; do
    case $1 in
        --map)
            if [[ $# -lt 2 ]]; then
                echo "> ERROR: --map requires a path" >&2
                exit 1
            fi
            MAP_PCD="$2"; shift 2 ;;
        -*)          EXTRA_ARGS+=("$1"); shift ;;
        *)
            if [[ -z "$SCAN_PCD" ]]; then
                SCAN_PCD="$1"
            else
                EXTRA_ARGS+=("$1")
            fi
            shift
            ;;
    esac
done

if [[ -z "$SCAN_PCD" ]]; then
    echo "Usage: offline-test <scan.pcd> [--map <map.pcd>] [extra ros2 launch args...]"
    exit 1
fi

SCAN_PCD="$(resolve_path "$SCAN_PCD")"
if [[ -z "$MAP_PCD" ]]; then
    MAP_PCD="$DEFAULT_MAP_PCD"
fi
MAP_PCD="$(resolve_path "$MAP_PCD")"

if [[ ! -f "$SCAN_PCD" ]]; then
    echo "> ERROR: Scan PCD not found: $SCAN_PCD" >&2; exit 1
fi
if [[ ! -f "$MAP_PCD" ]]; then
    echo "> ERROR: Map PCD not found: $MAP_PCD" >&2
    echo "> Hint: pass --map <map.pcd> or create ${DEFAULT_MAP_PCD}" >&2
    exit 1
fi

if [[ ! -f /opt/ros/jazzy/setup.bash ]]; then
    echo "> ERROR: ROS2 Jazzy not found" >&2; exit 1
fi
if [[ ! -f "${RADAR_WS}/ros_ws/install/setup.bash" ]]; then
    echo "> ERROR: Workspace not built. Run build-all or build-radar first." >&2; exit 1
fi

set +u
source /opt/ros/jazzy/setup.bash
source "${RADAR_WS}/ros_ws/install/setup.bash"
set -u

PARAMS_FILE="${RADAR_WS}/ros_ws/install/radar_lidar/share/radar_lidar/config/offline_registration.yaml"

echo "[offline-test] Launching offline registration visualization ..."
echo "[offline-test] map:  $MAP_PCD"
echo "[offline-test] scan: $SCAN_PCD"

# ros2 run 支持 -p key:=val 覆盖；--params-file 先加载默认值。
# 将脚本收集的额外参数 (含 -p ...) 原样透传给节点。
ros2 run radar_lidar offline_test_node --ros-args \
    --params-file "$PARAMS_FILE" \
    -p map_path:="$MAP_PCD" \
    -p scan_path:="$SCAN_PCD" \
    "${EXTRA_ARGS[@]}"
