#!/bin/bash
# setup-clangd-headers — 从 RADAR 容器提取 C++ 头文件到本地缓存，供宿主机 clangd 使用
# 用法: .script/setup-clangd-headers
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
CACHE_DIR="${REPO_ROOT}/.clangd-headers"
BUILD_ROOT="${REPO_ROOT}/ros_ws/build"

is_running() {
    [[ "$(docker inspect -f '{{.State.Running}}' "$1" 2>/dev/null)" == "true" ]]
}

# 手动 docker run (README 方式二) 用容器名 RADAR；
# Dev Container (README 推荐方式，docker compose) 用
# devcontainer-radar-develop-1。自动探测，可用 RADAR_CONTAINER 覆盖。
if [[ -n "${RADAR_CONTAINER:-}" ]]; then
    CONTAINER="${RADAR_CONTAINER}"
    if ! is_running "${CONTAINER}"; then
        echo "[setup-clangd-headers] ERROR: container '${CONTAINER}' (from \$RADAR_CONTAINER) is not running." >&2
        exit 1
    fi
elif is_running RADAR; then
    CONTAINER="RADAR"
elif is_running devcontainer-radar-develop-1; then
    CONTAINER="devcontainer-radar-develop-1"
else
    echo "[setup-clangd-headers] ERROR: no running RADAR container found." >&2
    echo "[setup-clangd-headers] Tried: RADAR, devcontainer-radar-develop-1" >&2
    echo "[setup-clangd-headers] Start the container first, or set RADAR_CONTAINER=<name>." >&2
    exit 1
fi

echo "[setup-clangd-headers] Extracting headers from container: ${CONTAINER}"
echo "[setup-clangd-headers] Cache dir: ${CACHE_DIR}"

if [[ ! -d "${BUILD_ROOT}" ]]; then
    echo "[setup-clangd-headers] ERROR: build directory not found: ${BUILD_ROOT}" >&2
    echo "[setup-clangd-headers] Run build-radar inside the container first." >&2
    exit 1
fi

mapfile -t COMPILE_DB_FILES < <(find "${BUILD_ROOT}" -mindepth 2 -maxdepth 2 -name compile_commands.json | sort)
if [[ ${#COMPILE_DB_FILES[@]} -eq 0 ]]; then
    echo "[setup-clangd-headers] ERROR: no compile databases found under ${BUILD_ROOT}" >&2
    exit 1
fi

mapfile -t PULL_PATHS < <(python3 - "${COMPILE_DB_FILES[@]}" <<'PY'
import json
import shlex
import sys

paths = {
    "/usr/include",
    "/usr/include/c++/14",
    "/usr/include/x86_64-linux-gnu/c++/14",
    "/usr/include/c++/14/backward",
    "/usr/lib/gcc/x86_64-linux-gnu/14/include",
}

for database_path in sys.argv[1:]:
    with open(database_path) as handle:
        entries = json.load(handle)
    for entry in entries:
        arguments = entry.get("arguments") or shlex.split(entry.get("command", ""))
        index = 1
        while index < len(arguments):
            argument = arguments[index]
            if argument in {"-I", "-isystem", "-iquote", "-idirafter"} and index + 1 < len(arguments):
                candidate = arguments[index + 1]
                index += 2
            elif argument.startswith("-I") and len(argument) > 2:
                candidate = argument[2:]
                index += 1
            else:
                index += 1
                continue

            stable_install_prefixes = (
                "/workspace/ros_ws/install/radar_interfaces/include",
                "/workspace/ros_ws/install/small_gicp/include",
            )
            if candidate.startswith(("/usr/", "/opt/ros/jazzy/", *stable_install_prefixes)):
                paths.add(candidate.rstrip("/"))

collapsed_paths = []
for path in sorted(paths, key=lambda value: (value.count("/"), value)):
    if any(path == parent or path.startswith(parent + "/") for parent in collapsed_paths):
        continue
    collapsed_paths.append(path)

print("\n".join(sorted(collapsed_paths)))
PY
)

TEMP_CACHE="$(mktemp -d "${CACHE_DIR}.tmp.XXXXXX")"
trap 'rm -rf "${TEMP_CACHE}"' EXIT

for src in "${PULL_PATHS[@]}"; do
    if docker exec "${CONTAINER}" test -d "${src}" 2>/dev/null; then
        rel="${src#/}"
        if [[ "${src}" == /workspace/ros_ws/install/* ]]; then
            rel="${src#/workspace/}"
        fi
        dest="${TEMP_CACHE}/${rel}"
        mkdir -p "$(dirname "${dest}")"
        echo "[setup-clangd-headers] Copying ${src} ..."
        if [[ "${src}" == /workspace/ros_ws/install/* ]]; then
            mkdir -p "${dest}"
            docker exec "${CONTAINER}" bash -lc '
                set -euo pipefail
                source_dir="$1"
                snapshot="$(mktemp -d)"
                trap '\''rm -rf "${snapshot}"'\'' EXIT
                cp -LR "${source_dir}/." "${snapshot}/"
                tar -C "${snapshot}" -cf - .
            ' bash "${src}" | tar -C "${dest}" -xf -
        else
            docker exec "${CONTAINER}" tar --dereference -C / -cf - "${rel}" | tar -C "${TEMP_CACHE}" -xf -
        fi
    else
        echo "[setup-clangd-headers] SKIP (not in container): ${src}"
    fi
done

if [[ -d "${CACHE_DIR}" ]]; then
    mv --exchange -T "${TEMP_CACHE}" "${CACHE_DIR}"
    rm -rf "${TEMP_CACHE}"
else
    mv -T "${TEMP_CACHE}" "${CACHE_DIR}"
fi
trap - EXIT

# ── 生成 .clangd (本机专属, 不进版本控制) ──────────────────────────
# clangd 的 CompileFlags.Add 不支持路径变量替换, 必须是每台机器的
# 真实绝对路径, 所以从模板生成而不是直接提交固定路径。
TEMPLATE="${SCRIPT_DIR}/template/clangd.template"
if [[ -f "${TEMPLATE}" ]]; then
    sed "s|__REPO_ROOT__|${REPO_ROOT}|g" "${TEMPLATE}" > "${REPO_ROOT}/.clangd"
    echo "[setup-clangd-headers] Generated ${REPO_ROOT}/.clangd from template"
else
    echo "[setup-clangd-headers] WARNING: template not found: ${TEMPLATE}" >&2
fi

echo "[setup-clangd-headers] Done."
echo "[setup-clangd-headers] .clangd cache refreshed at ${CACHE_DIR}"
echo "[setup-clangd-headers] 如果更换了容器或依赖，重新运行此脚本即可刷新缓存。"
