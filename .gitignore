/ros_ws/build
/ros_ws/install
/ros_ws/log
/ros_ws/MvSdkLog
compile_commands.json

# Build artifacts (root level)
/build/
/install/
/log/

# Docker
.env

# IDE
.vscode/settings.json
.mimocode/
.omo/
.clangd-headers/
# 由 .script/setup-clangd-headers 从 .script/template/clangd.template
# 生成, 含本机绝对路径, 不进版本控制 (clangd 不支持路径变量替换)。
/.clangd
tools/model_to_map/build/
tools/jinan_to_scan/build/

# Large point-cloud / map assets (never commit binary data)
/model/*.pcd
/model/*.fbx
/model/generated/

# Learnlog (local only)
learnlog.md

# Bag recordings / offline data (never commit binary data)
/map_recording_*/
**/__pycache__/

# Odin driver runtime logs (written to ros_ws/src/odin_ros_driver/log/ at runtime;
# driver source is a submodule under lidar_ros_driver/odin_ros_driver)
/ros_ws/src/odin_ros_driver/

# Script backups
*.bak
